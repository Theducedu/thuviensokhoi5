rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "nguyenduc91ltk@gmail.com";
    }

    function isOwnLoginStat(email) {
      return signedIn() && request.auth.token.email == email;
    }

    match /authorizedUsers/{email} {
      allow read: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow create, update, delete: if isAdmin();
    }

    match /loginStats/{email} {
      allow read: if isAdmin();
      allow create, update: if isOwnLoginStat(email);
      allow delete: if isAdmin();
    }
  }
}
