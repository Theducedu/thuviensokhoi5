rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "nguyenduc91ltk@gmail.com";
    }

    function isOwnLoginStat(email) {
      return signedIn() && request.auth.token.email == email;
    }

    function isStaff() {
      return signedIn()
        && exists(/databases/$(database)/documents/authorizedUsers/$(request.auth.token.email))
        && get(/databases/$(database)/documents/authorizedUsers/$(request.auth.token.email)).data.active == true;
    }

    match /authorizedUsers/{email} {
      allow read: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow create, update, delete: if isAdmin();
    }

    match /loginStats/{email} {
      allow read: if isAdmin();
      allow create, update: if isOwnLoginStat(email);
      allow delete: if isAdmin();
    }

    match /resources/{id} {
      allow read: if signedIn();
      allow create, update: if isAdmin() || isStaff();
      allow delete: if isAdmin();
    }

    match /news/{id} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
                    (isStaff() && request.resource.data.visible == false);
      allow update, delete: if isAdmin();
    }

    match /guides/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /digitalApps/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /deletedDefaults/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
